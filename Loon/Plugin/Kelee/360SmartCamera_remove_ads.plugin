[Rule]
DOMAIN, ad.jia.360.cn, REJECT
DOMAIN, ad.iot.360.cn, REJECT

[Rewrite]
^https:\/\/jia\.360\.cn\/conf\/v1\.json response-body-json-del tab_conf ad_conf activity
 
[MitM]
hostname=jia.360.cn