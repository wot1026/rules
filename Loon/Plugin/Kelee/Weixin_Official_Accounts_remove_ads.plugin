#!name=微信公众号去广告
#!desc=过滤微信公众号广告
#App链接=https://apps.apple.com/app/id414478124
#!author=RuCu6[https://github.com/wot1026/rules/blob/X/Loon/Readme.md]
#!tag=去广告
#!system=
#!system_version=
#!loon_version=3.4.0(962)
#!homepage=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/Weixin_Official_Accounts_remove_ads.plugin
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/Weixin.png
#!date=2026-06-01 17:11:35

[Rule]
DOMAIN-SUFFIX, wxs.qq.com, REJECT

[Rewrite]
^https:\/\/mp\.weixin\.qq\.com\/mp\/(cps_product_info|getappmsgad|jsmonitor|masonryfeed|relatedarticle)\? reject-dict

^https:\/\/mp\.weixin\.qq\.com\/mp\/relatedsearchword reject-dict


[MitM]
hostname=mp.weixin.qq.com