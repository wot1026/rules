[Script]
http-request ^https?:\/\/apapia-sqk-weblogic\.manmanbuy\.com\/baoliao\/center\/menu$ script-path=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/Script/JD_Price.js, requires-body=true, timeout=10, tag=捕获令牌

http-response ^https?:\/\/in\.m\.jd\.com\/product\/graphext\/\d+\.html script-path=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/Script/JD_Price.js, requires-body=true, timeout=10, tag=京东比价

[MitM]
hostname=in.m.jd.com, apapia-sqk-weblogic.manmanbuy.com