[Rule]
URL-REGEX, "^http?:\/\/(discardrp|startup)\.umetrip\.com\/gateway\/api\/umetrip\/native", REJECT

[Script]
http-response ^http?:\/\/(114\.115\.217\.129)|(home\.umetrip\.com)\/gateway\/api\/umetrip\/native$ script-path=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/Script/Umetrip_remove_ads.js, tag=移除首页广告

[MitM]
hostname=114.115.217.129, home.umetrip.com