#!name=TestFlight地区解锁
#!desc=解除TestFlight的区域限制，支持tvOS。
#App链接=https://apps.apple.com/app/id899247664
#!author=可莉🅥[https://github.com/wot1026/rules/blob/X/Loon/Readme.md]
#!tag=功能增强
#!system=
#!system_version=
#!loon_version=3.4.0(962)
#!homepage=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/TestFlightRegionUnlock.plugin
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/TestFlight.png
#!date=2026-06-01 17:11:35

[Rule]
DOMAIN, testflight.apple.com, PROXY

[Rewrite]
^https?:\/\/testflight\.apple\.com\/v\d\/accounts\/.+?\/install$ request-body-replace-regex "storefrontId"\x20:\x20"\d{6}-\d{2},\d{2}", "storefrontId":"143441-19,29",

[MitM]
hostname=testflight.apple.com