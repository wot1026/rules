#!name=最右去广告
#!desc=移除开屏广告、信息流广告和广告轮播图。
#App链接=https://apps.apple.com/app/id942443472
#!author=可莉🅥[https://github.com/wot1026/rules/blob/X/Loon/Readme.md]
#!tag=去广告
#!system=
#!system_version=
#!loon_version=3.4.0(962)
#!homepage=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/ZuiYou_remove_ads.plugin
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/ZuiYou.png
#!date=2026-06-01 17:11:35

[Rule]
DOMAIN, adapi.izuiyou.com, REJECT
URL-REGEX, "^http:\/\/mercury-gateway\.ixiaochuan\.cn\/mercury\/v1\/ad\/", REJECT-DICT
URL-REGEX, "^http:\/\/file-share\.izuiyou\.com\/octopus\/media\/templates\/search_home_page_(nv|nv_v2)\/search_home_page_nv", REJECT

[Rewrite]
^https?:\/\/api\.izuiyou\.com\/config\/get_banner reject-dict
^https?:\/\/api\.izuiyou\.com\/ad\/ reject
^https:\/\/zyfile\.izuiyou\.com\/zyfile\/c2\/a0\/[a-z0-9-]+\.json reject-dict

[MitM]
hostname=api.izuiyou.com, zyfile.izuiyou.com