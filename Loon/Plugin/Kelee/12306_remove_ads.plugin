#!name=12306去广告
#!desc=过滤12306应用内广告及开屏广告
#App链接=https://apps.apple.com/app/id564818797
#!author=RuCu6[https://github.com/RuCu6], 可莉🅥[https://github.com/wot1026/rules/blob/X/Loon/Readme.md]
#!tag=去广告
#!system=
#!system_version=
#!loon_version=3.4.0(962)
#!homepage=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/12306_remove_ads.plugin
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/12306.png
#!date=2026-06-01 17:11:35

[Rule]
DOMAIN, ad.12306.cn, DIRECT

[Rewrite]
^https:\/\/ad\.12306\.cn\/ad\/ser\/getAdList$ response-body-json-del materialsList advertParam

[Script]

http-request ^https:\/\/mobile\.12306\.cn\/otsmobile\/app\/mgs\/mgw\.htm$ script-path=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/Script/12306_remove_ads.js, tag=移除12306应用内广告

[MitM]
hostname=ad.12306.cn, mobile.12306.cn