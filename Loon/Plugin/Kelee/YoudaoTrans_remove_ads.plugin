[Rewrite]
^https:\/\/gorgon\.youdao\.com\/gorgon\/v2\/request\.s reject-dict
^https:\/\/gorgon\.youdao\.com\/gorgon\/brand\/prefetch\.s reject-dict

^https:\/\/gorgon\.youdao\.com\/gorgon\/request\.s reject-dict
^https:\/\/fanyiguan-server\.youdao\.com\/server\/banner\? reject-dict
^https:\/\/dict\.youdao\.com\/vip\/activity\/fanyiguan\/sevendayfree\/imei\? reject-dict

^https:\/\/dict\.youdao\.com\/wordbook\/recommend\?all=false reject-dict

^https:\/\/api-overmind\.youdao\.com\/openapi\/get\/luna\/dict\/trans_abtest\/online\/iOS\? reject-dict

[MitM]
hostname=gorgon.youdao.com, fanyiguan-server.youdao.com, api-overmind.youdao.com, dict.youdao.com