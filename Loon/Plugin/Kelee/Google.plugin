#!name=Google搜索重定向
#!desc=将Google搜索重定向至.com域名，如遇频繁跳转请禁用本插件。
#App链接=
#!author=可莉🅥[https://github.com/wot1026/rules/blob/X/Loon/Readme.md]
#!tag=去广告
#!system=
#!system_version=
#!loon_version=3.4.0(962)
#!homepage=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/Google.plugin
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/Google.png
#!date=2026-06-01 17:11:35

[Rewrite]
^https?:\/\/(www.)?(g|google)\.cn 307 https://www.google.com
^https?:\/\/(ditu|maps).google\.cn 307 https://maps.google.com

[MitM]
hostname=www.google.cn