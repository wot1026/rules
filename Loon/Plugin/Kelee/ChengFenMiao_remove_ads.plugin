[Rewrite]
^https:\/\/app\.chengfenmiao\.com\/Listing\/LiveHots\? reject-dict

^https:\/\/app\.chengfenmiao\.com\/helper\/VersionCheck\? reject-dict

^https:\/\/app\.chengfenmiao\.com\/item\/closet\? reject-dict
^https:\/\/app\.chengfenmiao\.com\/helper\/setting\? response-body-json-del detail_buy_sites bottom_sites

^https:\/\/app\.chengfenmiao\.com\/Helper\/HotWords\? reject-dict
 
[MitM]
hostname=app.chengfenmiao.com