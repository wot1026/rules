#!name=Follow每日签到
#!desc=Follow每日签到，需要进入此插件的主页链接，阅读使用说明操作。
#App链接=https://follow.is
#!author=gideonsenku[https://github.com/gideonsenku], 可莉🅥[https://github.com/wot1026/rules/blob/X/Loon/Readme.md]
#!tag=签到
#!system=
#!system_version=
#!loon_version=3.4.0(962)
#!homepage=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/FollowRSS_checkin.plugin
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/FollowRSS.png
#!date=2026-06-01 17:11:35

[Argument]
token=input, "", tag=csrfToken, desc=这里需要输入csrfToken的值
cookie=input, "", tag=Cookie, desc=这里需要输入Cookie的值
cron=input, "0 1 * * *", tag=定时参数, desc=这里需要输入符合CRON表达式的参数

[Script]
cron {cron} script-path=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/Script/FollowRSS_checkin.js, tag=Follow每日签到, timeout=120, argument=[{token},{cookie}]

[MitM]
hostname=api.follow.is