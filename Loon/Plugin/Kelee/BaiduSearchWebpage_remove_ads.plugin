#!name=百度网页去广告
#!desc=移除百度搜索移动端网页的首页广告信息流
#App链接=
#!author=Keywos[https://github.com/wot1026/rules/blob/X/Loon/Readme.md]
#!tag=去广告
#!system=
#!system_version=
#!loon_version=3.4.0(962)
#!homepage=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/BaiduSearchWebpage_remove_ads.plugin
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/Baidu.png
#!date=2026-06-01 17:11:35

[Script]
http-response ^https?:\/\/(www|m)\.baidu\.com\/?($|\?from=\w{8,9}) script-path=https://github.com/wot1026/rules/raw/X/Loon/Plugin/Kelee/Script/BaiduSearchHomePage_remove_ads.js, requires-body=true, tag=移除百度搜索首页信息流广告

[MitM]
hostname=m.baidu.com, www.baidu.com